{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PopForge",
  "version": "0.4.0",
  "identifier": "com.brunosgits.popforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PopForge"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$CACHE/**"]
      }
    }
  },
  "bundle": {
  "active": true,
  "targets": "all",

  "externalBin": [
    "bin/PSXPackager"
  ],

  "resources": [
    "bin/Resources"
  ],

  "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.icns",
    "icons/icon.ico"
  ]
}
}
