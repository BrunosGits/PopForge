# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Bundled conversion tools (user-supplied)
# Keep bin/ tracked via .gitkeep, but never commit the binaries themselves.
# Match both the bare name and any `<tool>-<target-triple>` suffix produced by
# Tauri's externalBin resolution.
/bin/PSXPackager
/bin/PSXPackager-*
/bin/PSXPackager.exe
/bin/PSXPackager-*.exe
/bin/chdman
/bin/chdman-*
/bin/chdman.exe
/bin/chdman-*.exe
/bin/*.dylib
/bin/*.so
/bin/*.dll
